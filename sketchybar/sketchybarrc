#!/bin/bash

FONT="JetBrainsMono Nerd Font"
PLUGIN_DIR="$HOME/.config/sketchybar/plugins"

# Kanagawa-inspired palette
BAR_COLOR=0x00000000
ISLAND_BG=0xee16161d
BORDER=0x28cdd6f4
ACCENT=0xff7aa2f7
TEXT=0xffcad3f5
DIM=0xff545c7e
GREEN=0xff9ece6a
YELLOW=0xffe0af68

# Floating transparent bar
sketchybar --bar \
  position=top \
  height=36 \
  color=$BAR_COLOR \
  border_width=0 \
  margin=0 \
  padding_left=12 \
  padding_right=12 \
  y_offset=8 \
  shadow=off

# Defaults — no background by default, islands handle grouping
sketchybar --default \
  icon.font="$FONT:Bold:13.0" \
  label.font="$FONT:Medium:12.0" \
  icon.color=$ACCENT \
  label.color=$TEXT \
  background.height=26 \
  background.corner_radius=6 \
  background.color=0x00000000 \
  background.border_width=0 \
  padding_left=0 \
  padding_right=0 \
  label.padding_left=4 \
  label.padding_right=4 \
  icon.padding_left=6 \
  icon.padding_right=4

# --- Workspaces (left island) ---
sketchybar --add event aerospace_workspace_change

WS_ITEMS=()
for sid in $(aerospace list-workspaces --all); do
  WS_ITEMS+=("ws.$sid")
  sketchybar --add item ws.$sid left \
    --subscribe ws.$sid aerospace_workspace_change \
    --set ws.$sid \
    icon="$sid" \
    icon.font="$FONT:Bold:13.0" \
    label.drawing=off \
    background.color=0x00000000 \
    background.border_width=0 \
    background.height=26 \
    background.corner_radius=6 \
    icon.color=$DIM \
    icon.padding_left=8 \
    icon.padding_right=8 \
    padding_left=2 \
    padding_right=2 \
    click_script="aerospace workspace $sid" \
    script="$PLUGIN_DIR/workspace.sh"
done

sketchybar --add bracket ws_bracket "${WS_ITEMS[@]}" \
  --set ws_bracket \
  background.color=$ISLAND_BG \
  background.border_width=1 \
  background.border_color=$BORDER \
  background.corner_radius=10 \
  background.height=32

# --- Front App (center island) ---
sketchybar --add item front_app center \
  --set front_app \
  icon.drawing=off \
  label.color=$TEXT \
  label.font="$FONT:SemiBold:13.0" \
  label.padding_left=14 \
  label.padding_right=14 \
  background.color=$ISLAND_BG \
  background.border_width=1 \
  background.border_color=$BORDER \
  background.corner_radius=10 \
  background.height=32 \
  background.drawing=on \
  script="$PLUGIN_DIR/front_app.sh" \
  --subscribe front_app front_app_switched

# --- Right island: wifi · battery · clock ---
sketchybar --add item wifi right \
  --set wifi \
  icon=󰖩 \
  icon.color=$ACCENT \
  icon.padding_left=14 \
  icon.padding_right=4 \
  label.padding_right=4 \
  background.drawing=off \
  script="$PLUGIN_DIR/wifi.sh" \
  update_freq=20

sketchybar --add item battery right \
  --set battery \
  icon=󰁹 \
  icon.color=$GREEN \
  icon.padding_left=10 \
  icon.padding_right=4 \
  label.padding_right=4 \
  background.drawing=off \
  script="$PLUGIN_DIR/battery.sh" \
  update_freq=60 \
  --subscribe battery system_woke power_source_change

sketchybar --add item clock right \
  --set clock \
  icon=󰥔 \
  icon.color=$YELLOW \
  icon.padding_left=10 \
  icon.padding_right=4 \
  label.padding_right=14 \
  background.drawing=off \
  script="$PLUGIN_DIR/clock.sh" \
  update_freq=10

sketchybar --add bracket info_bracket wifi battery clock \
  --set info_bracket \
  background.color=$ISLAND_BG \
  background.border_width=1 \
  background.border_color=$BORDER \
  background.corner_radius=10 \
  background.height=32

sketchybar --update
